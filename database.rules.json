{
  "rules": {
    "players": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "gamePlayers": {
      "$room": {
        ".read": "auth != null",
        "$emailKey": {
          ".write": "auth != null",
          ".validate": "!newData.exists() || newData.child('email').val() === auth.token.email"
        }
      }
    },

    "leaderboard": {
      "global": {
        ".read": "auth != null",
        "$emailKey": {
          ".write": "auth != null",
          ".validate": "newData.child('email').val() === auth.token.email"
        }
      },
      "class": {
        "$classCode": {
          ".read": "auth != null",
          "$emailKey": {
            ".write": "auth != null",
            ".validate": "newData.child('email').val() === auth.token.email"
          }
        }
      }
    },

    "challenges": {
      "$toEmailKey": {
        ".read": "auth != null",
        "$room": {
          ".write": "auth != null"
        }
      }
    },

    "activity": {
      "daily": {
        "$date": {
          ".read": "auth != null && root.child('coaches').child(auth.uid).val() === true",
          "$emailKey": {
            ".write": "auth != null",
            ".validate": "newData.child('email').val() === auth.token.email"
          }
        }
      }
    },

    "coaches": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid"
      }
    }
  }
}
